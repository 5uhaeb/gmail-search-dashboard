// Prisma schema for MailBoard
// Uses PostgreSQL in production (for example Vercel + Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  createdAt      DateTime        @default(now())
  savedSearches  SavedSearch[]
  searchHistory  SearchHistory[]
  preferences    UserPreference?
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String
  filters   String   // JSON-serialized filter object
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  filters   String   // JSON-serialized filter object
  resultCnt Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  theme         String   @default("system") // "light" | "dark" | "system"
  viewMode      String   @default("messages") // "messages" | "threads"
  pageSize      Int      @default(25)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
